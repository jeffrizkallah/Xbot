# Copy to .env for local runs. In GitHub Actions, set these as repository secrets.

# Claude API
ANTHROPIC_API_KEY=

# Telegram bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=
# Your personal Telegram chat ID (message @userinfobot to get it)
TELEGRAM_CHAT_ID=
# Twitter / X API v2 (from developer.twitter.com — Basic tier)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=

# Optional: enable X search for trading sentiment (needs Basic tier read)
ENABLE_X_SEARCH=false

# For the Telegram "run" command — GitHub PAT with workflow dispatch permission
# Fine-grained token: repo-scoped to jeffrizkallah/Xbot, "Actions: read/write"
GH_REPO=jeffrizkallah/Xbot
GH_WORKFLOW_TOKEN=

# Cloudflare Worker webhook (for instant responses)
# Generate a long random string — it's used to verify Telegram requests.
TELEGRAM_WEBHOOK_SECRET=

